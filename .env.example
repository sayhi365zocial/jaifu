# Postgres connection string for Jaifu's OWN database.
# Railway injects this automatically when you attach a Postgres plugin to
# the service. For local dev, paste a connection string here in .env.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Set PGSSL=disable for a local non-SSL Postgres; leave unset for Railway/Neon.
# PGSSL=disable

# Optional: only if the API is hosted on a different origin than the app.
# Leave unset — the server serves the API same-origin.
# VITE_API_BASE_URL=

# Where the "ติชม" button points (LINE OA, Google Form, ...).
# Leave unset to use the default: mailto:sayhi@365zocial.com
VITE_FEEDBACK_URL=
